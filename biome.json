{
	"$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"files": {
		"include": ["./src/**/*.{html,js,svelte,ts}"]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useButtonType": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 180
	},
	"javascript": {
		"formatter": {
			"trailingComma": "none",
			"semicolons": "always",
			"quoteStyle": "double"
		}
	}
}
